<launch>
  <!-- Include the robot URDF/Xacro for visualization -->
  <param name="robot_description" command="$(find xacro)/xacro $(find finaldesign_description)/urdf/finaldesign.xacro"/>

  <!-- Run the slam_gmapping node -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <!-- Basic parameters -->
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_update_interval" value="5.0"/>
    
    <!-- Laser parameters -->
    <param name="maxRange" value="30.0"/>
    <param name="minRange" value="0.1"/>
    <param name="particles" value="100"/>
    
    <!-- Adjust these parameters based on your robot's configuration and testing -->
    <param name="sigma" value="0.05"/>
    <param name="kernelSize" value="1"/>
    <param name="lstep" value="0.05"/>
    <param name="astep" value="0.05"/>
    <param name="iterations" value="5"/>
    <param name="lsigma" value="0.075"/>
    <param name="ogain" value="3.0"/>
    <param name="lskip" value="0"/>
    
    <!-- Set the laser's topic -->
    <remap from="scan" to="/scan"/>
  </node>
  
  <!-- Optional: Include other nodes here, such as for robot control or visualization -->
  
</launch>